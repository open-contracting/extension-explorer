{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "**",
      "!extension_explorer/templates/**/*.html",
      "!extension_explorer/static/lib/*.min.js",
      "!extension_explorer/static/lib/bootstrap",
      "!extension_explorer/static/css/theme.css",
      "!extension_explorer/static/css/pygments.css"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 119
  },
  "json": {
    "formatter": {
      "indentWidth": 2
    }
  },
  "linter": {
    "enabled": true
  }
}
