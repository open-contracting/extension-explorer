{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 119
  },
  "files": {
    "includes": [
      "**",
      "!extension_explorer/templates/**/*.html",
      "!extension_explorer/static/lib/*.min.js",
      "!extension_explorer/static/lib/bootstrap",
      "!extension_explorer/static/css/pygments.css"
    ]
  }
}
